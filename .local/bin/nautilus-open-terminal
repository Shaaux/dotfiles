#!/bin/bash
#
# Smart terminal opener for Ctrl+Return keybinding
# - In Nautilus: opens new tmux window in current directory (no duplicate ghostty)
# - Anywhere else: opens ghostty normally (attaches to existing tmux session)

TMUX_SESSION_NAME="main"

active_class=$(hyprctl activewindow -j | jq -r '.class')

if [[ "$active_class" == "org.gnome.Nautilus" ]]; then
    # === NAUTILUS FOCUSED ===
    # Get directory from Nautilus via D-Bus FileManager1 interface
    uri=$(gdbus call --session --dest org.freedesktop.FileManager1 \
        --object-path /org/freedesktop/FileManager1 \
        --method org.freedesktop.DBus.Properties.Get \
        org.freedesktop.FileManager1 OpenLocations 2>/dev/null | \
        grep -oP "file://[^'\"]*" | head -1)
    
    path="${uri#file://}"
    
    if [[ -d "$path" ]]; then
        if tmux has-session -t "$TMUX_SESSION_NAME" 2>/dev/null; then
            # Session exists - create new window with this directory
            tmux new-window -t "$TMUX_SESSION_NAME" -c "$path"
            
            # Only open ghostty if no clients attached
            if ! tmux list-clients -t "$TMUX_SESSION_NAME" 2>/dev/null | grep -q .; then
                exec ghostty --working-directory="$path"
            fi
        else
            # No session - open ghostty which will create it
            exec ghostty --working-directory="$path"
        fi
    fi
else
    # === ANY OTHER APP ===
    # Just open ghostty normally (attaches to existing session, duplicates are fine)
    exec ghostty
fi
